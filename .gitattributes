# Auto detect text files and normalise line endings
* text=auto

# Shell scripts must use LF
*.sh text eol=lf
gradlew text eol=lf

# Windows batch files must use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.jar binary
*.jks binary
*.keystore binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
